          "timestamp": "2026-07-01T12:00:00+00:00"
        },
        "hash": "2325f7cb76ad04aab9da41ab5e2b0a5e312c1ab76fb16965fd1e8bafc128a4d6"
      }
    ],
    "rule": {
      "rule_id": "rule-single-agent-v1",
      "issuer": "did:fly:demo-platform",
      "version": "1.0.0",
      "hash": "4eeede5dee38e7cd466b6a21aed75b0e9883ac74783b7682b3ff99dfe3e8c1e5",
      "definition": {
        "name": "单Agent全额归因规则",
