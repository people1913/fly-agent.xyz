    "claim_integrity",
    "evidence_hash_integrity",
    "evidence_claim_ref",
    "attribution_consistency",
    "settlement_correctness",
    "rule_integrity",
    "attribution_rule_binding",
    "rule_registration",
    "issuer_trust"
