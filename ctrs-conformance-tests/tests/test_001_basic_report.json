{
  "test_id": "test_001",
  "name": "基础 CTRS Report 生成",
  "description": "验证单个 Agent 的基础归因场景 — 单一 Agent 推荐 + 用户购买，100% 归因",
  "layer": 1,
  "category": "positive",
  "input": {
    "claim": {
      "claim_id": "claim-001-basic",
      "type": "single_agent_conversion",
      "subject": "用户通过单一 Agent 完成产品推荐并购买",
      "description": "Agent A 推荐产品，用户完成购买。交易金额 $500。",
      "timestamp": "2026-07-01T10:00:00+00:00",
      "parties": [
        {"id": "agent-a", "role": "recommender", "name": "推荐 Agent"},
        {"id": "user-001", "role": "buyer", "name": "用户A"}
      ]
    },
    "evidence": [
      {
        "evidence_id": "ev-001-1",
        "claim_ref": "claim-001-basic",
        "type": "conversation",
        "source": "agent-a",
        "timestamp": "2026-07-01T10:00:00+00:00",
        "data": {
          "conversation_id": "conv-001",
          "agent_id": "agent-a",
          "user_id": "user-001",
          "action": "recommend_product",
          "product": "智能手环 SmartBand S1",
          "timestamp": "2026-07-01T10:00:00+00:00",
          "message": "推荐 SmartBand S1，售价 $500"
        },
        "hash": "fa12fe557fe4f787022e58bb2015a4584bf901db376a1015af6b3dd894afdda1"
      }
    ],
    "rule": {
      "rule_id": "rule-single-agent-v1",
      "issuer": "did:fly:demo-platform",
      "version": "1.0.0",
      "hash": "4eeede5dee38e7cd466b6a21aed75b0e9883ac74783b7682b3ff99dfe3e8c1e5",
      "definition": {
        "name": "单Agent全额归因规则",
        "method": "proportional",
        "description": "单一 Agent 获得 100% 归因",
        "parameters": {
          "total_value": "500",
          "currency": "USD",
          "splits": {"agent-a": "100"}
        }
      },
      "created_at": "2026-07-01T09:00:00+00:00"
    }
  },
  "expected_output": {
    "schema_version": "CTRS-v1.2",
    "type": "CommercialTrustReport",
    "claim.claim_id": "存在",
    "evidence_count": 1,
    "rule.rule_id": "存在",
    "attribution.rule_hash": "等于 rule.hash",
    "settlement.status": "eligible",
    "settlement.split_sum": "等于 settlement.amount"
  },
  "checks": [
    "schema_completeness",
    "claim_integrity",
    "evidence_hash_integrity",
    "evidence_claim_ref",
    "attribution_consistency",
    "settlement_correctness",
    "rule_integrity",
    "attribution_rule_binding",
    "rule_registration",
    "issuer_trust"
  ],
  "expected_result": "PASS"
}
