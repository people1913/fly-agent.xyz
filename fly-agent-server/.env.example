# Fly GEO Agent Server - Environment Configuration Template
# Copy this to .env and fill in your values

# Network settings
NETWORK=bsc-mainnet
RPC_URL=https://bsc-dataseed.binance.org

# Provider wallet (Owner of this agent)
# IMPORTANT: Remove this after first run, the SDK will use encrypted keystore
PRIVATE_KEY=your_private_key_here
WALLET_PASSWORD=your_wallet_password_here

# ERC-8183 Contract addresses (BSC Mainnet)
ERC8183_COMMERCE_ADDRESS=0xea4daa3100a767e886fded867729ae7446476eba6
ERC8183_ROUTER_ADDRESS=0x51895229e12f9876011789b04f8698af06ccd6da
ERC8183_POLICY_ADDRESS=0x9c01845705b3078aa2e8cff7520a6376fd766de5
ERC8183_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432

# Payment Token (USDT on BSC)
PAYMENT_TOKEN_ADDRESS=0x55d398326f99059fF775485246999027B3197955

# Service pricing (in wei, 1 token = 10^18)
# 9.9 USDT = 9,900,000,000,000,000,000 wei
ERC8183_SERVICE_PRICE=9900000000000000000

# Agent URL for ERC-8183 callbacks
ERC8183_AGENT_URL=http://localhost:8003/erc8183

# Server port
PORT=8003

# MegaFuel Paymaster for gas-free transactions
ERC8183_PAYMASTER_URL=https://bsc-megafuel.nodereal.io/

# Storage provider (local filesystem)
ERC8183_LOCAL_STORAGE_PATH=/tmp/fly-agent-storage

# Funded job polling interval (seconds)
ERC8183_FUNDED_POLL_INTERVAL=30

# Rate limiting for negotiate endpoint
ERC8183_NEGOTIATE_RATE_LIMIT=120
ERC8183_NEGOTIATE_RATE_WINDOW=60

# Response size limits
ERC8183_MAX_RESPONSE_BYTES=5242880
ERC8183_MAX_METADATA_BYTES=262144

# DeepSeek API for GEO diagnosis
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
