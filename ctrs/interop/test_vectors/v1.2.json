{
  "version": "1.2",
  "description": "CTRS v1.2 互操作测试向量。供不同语言实现验证其 Report 生成和验证逻辑的正确性。每个向量包含完整的 expected 结构（report + verify_result + settlement），并标注对应的 compliance_level。",
  "test_vectors": [
    {
      "id": "tv-001",
      "description": "基础归因场景：单 Agent 推荐促成转化",
      "compliance_level": "ctrs-core",
      "compliance_level_notes": "此向量仅涉及 Core 级别验证规则（VR-101~VR-402），无需 Registry 即可完整验证",
      "input": {
        "claim": {
          "claim_id": "c-tv001",
          "type": "single_agent_conversion",
          "subject": "用户购买产品，由单一 Agent 推荐",
          "description": "Agent A 推荐产品，用户直接购买。交易金额 $100。",
          "timestamp": "2026-07-01T10:00:00+00:00",
          "parties": [
            {"id": "agent-a", "role": "recommender", "name": "Agent A"},
            {"id": "user-1", "role": "buyer", "name": "User"}
          ]
        },
        "evidence": [
          {
            "evidence_id": "e-tv001-1",
            "claim_ref": "c-tv001",
            "type": "conversation",
            "source": "agent-a",
            "timestamp": "2026-07-01T10:00:10+00:00",
            "data": {
              "action": "recommend_product",
              "product_id": "prod-001",
              "message": "推荐产品 A，售价 $100"
            },
            "hash": "PLACEHOLDER_COMPUTE_SHA256"
          }
        ],
        "rule": {
          "rule_id": "rule-single-agent-v1",
          "issuer": "did:fly:test-platform",
          "version": "1.0.0",
          "hash": "PLACEHOLDER_COMPUTE_SHA256",
          "definition": {
            "name": "单Agent归因规则",
            "method": "proportional",
            "description": "推荐Agent获得100%归因",
            "parameters": {
              "total_value": "100",
              "currency": "USD",
              "splits": {"agent-a": "100"}
            }
          },
          "created_at": "2026-07-01T10:00:00+00:00"
        }
      },
      "expected": {
        "report": {
          "schema_version": "CTRS-v1.2",
          "type": "CommercialTrustReport",
          "claim.claim_id": "c-tv001",
          "evidence_count": 1,
          "attribution.rule_hash": "等于 rule.hash",
          "attribution.claim_ref": "等于 claim.claim_id",
          "settlement.attribution_ref": "等于 attribution.attribution_id",
          "status": "eligible"
        },
        "verify_result": {
          "status": "valid",
          "compliance_level": "ctrs-core",
          "checks": {
            "schema_completeness": true,
            "claim_integrity": true,
            "evidence_hash_integrity": true,
            "evidence_claim_ref": true,
            "attribution_consistency": true,
            "settlement_correctness": true,
            "rule_integrity": true,
            "attribution_rule_binding": true,
            "rule_registration": true,
            "issuer_trust": true
          },
          "failed_checks": [],
          "total_passed": 10,
          "total_failed": 0
        },
        "settlement": {
          "status": "eligible",
          "amount": "100",
          "currency": "USD",
          "split_sum": "100",
          "split": [
            {"party_id": "agent-a", "share_pct": "100", "share_amount": "100"}
          ],
          "eligible_parties_count": 1
        }
      }
    },
    {
      "id": "tv-002",
      "description": "多 Agent 协作归因场景：推荐+讲解+支付",
      "compliance_level": "ctrs-core",
      "compliance_level_notes": "此向量仅涉及 Core 级别验证规则（VR-101~VR-402），无需 Registry 即可完整验证",
      "input": {
        "claim": {
          "claim_id": "c-tv002",
          "type": "multi_agent_conversion",
          "subject": "用户购买高级产品，由三个 Agent 协作促成",
          "description": "Agent A 推荐 → Agent B 讲解 → Agent C 完成支付。交易金额 $2400。",
          "timestamp": "2026-07-01T12:00:00+00:00",
          "parties": [
            {"id": "agent-a", "role": "recommender", "name": "推荐 Agent"},
            {"id": "agent-b", "role": "explainer", "name": "讲解 Agent"},
            {"id": "agent-c", "role": "payment_agent", "name": "支付 Agent"},
            {"id": "user-1", "role": "buyer", "name": "User"}
          ]
        },
        "evidence": [
          {
            "evidence_id": "e-tv002-1",
            "claim_ref": "c-tv002",
            "type": "conversation",
            "source": "agent-a",
            "timestamp": "2026-07-01T12:00:10+00:00",
            "data": {
              "action": "recommend_product",
              "product_id": "prod-premium",
              "message": "推荐 Premium 产品，售价 $2400"
            },
            "hash": "PLACEHOLDER_COMPUTE_SHA256"
          },
          {
            "evidence_id": "e-tv002-2",
            "claim_ref": "c-tv002",
            "type": "conversation",
            "source": "agent-b",
            "timestamp": "2026-07-01T12:00:20+00:00",
            "data": {
              "action": "explain_product",
              "product_id": "prod-premium",
              "details": "高端做工，五年质保"
            },
            "hash": "PLACEHOLDER_COMPUTE_SHA256"
          },
          {
            "evidence_id": "e-tv002-3",
            "claim_ref": "c-tv002",
            "type": "payment",
            "source": "agent-c",
            "timestamp": "2026-07-01T12:00:30+00:00",
            "data": {
              "action": "process_payment",
              "transaction_id": "TXN-001",
              "amount": 2400,
              "currency": "USD",
              "status": "completed"
            },
            "hash": "PLACEHOLDER_COMPUTE_SHA256"
          }
        ],
        "rule": {
          "rule_id": "rule-multi-agent-v1",
          "issuer": "did:fly:test-platform",
          "version": "1.0.0",
          "hash": "PLACEHOLDER_COMPUTE_SHA256",
          "definition": {
            "name": "三Agent协作归因规则",
            "method": "proportional",
            "description": "推荐45% / 讲解35% / 支付渠道20%",
            "parameters": {
              "total_value": "2400",
              "currency": "USD",
              "splits": {"agent-a": "45", "agent-b": "35", "agent-c": "20"}
            }
          },
          "created_at": "2026-07-01T12:00:00+00:00"
        }
      },
      "expected": {
        "report": {
          "schema_version": "CTRS-v1.2",
          "type": "CommercialTrustReport",
          "claim.claim_id": "c-tv002",
          "evidence_count": 3,
          "attribution.rule_hash": "等于 rule.hash",
          "attribution.claim_ref": "等于 claim.claim_id",
          "settlement.attribution_ref": "等于 attribution.attribution_id",
          "status": "eligible"
        },
        "verify_result": {
          "status": "valid",
          "compliance_level": "ctrs-core",
          "checks": {
            "schema_completeness": true,
            "claim_integrity": true,
            "evidence_hash_integrity": true,
            "evidence_claim_ref": true,
            "attribution_consistency": true,
            "settlement_correctness": true,
            "rule_integrity": true,
            "attribution_rule_binding": true,
            "rule_registration": true,
            "issuer_trust": true
          },
          "failed_checks": [],
          "total_passed": 10,
          "total_failed": 0
        },
        "settlement": {
          "status": "eligible",
          "amount": "2400",
          "currency": "USD",
          "split_sum": "2400",
          "split": [
            {"party_id": "agent-a", "share_pct": "45", "share_amount": "1080"},
            {"party_id": "agent-b", "share_pct": "35", "share_amount": "840"},
            {"party_id": "agent-c", "share_pct": "20", "share_amount": "480"}
          ],
          "eligible_parties_count": 3
        }
      }
    },
    {
      "id": "tv-003",
      "description": "带置信度的归因场景：部分归因",
      "compliance_level": "ctrs-core",
      "compliance_level_notes": "此向量仅涉及 Core 级别验证规则（VR-101~VR-402），包含 confidence 浮点数验证（VR-110）",
      "input": {
        "claim": {
          "claim_id": "c-tv003",
          "type": "partial_attribution",
          "subject": "用户购买产品，Agent 推荐但用户已有购买意向",
          "description": "Agent A 提供了产品推荐，但用户此前已浏览过该产品。交易金额 $500。",
          "timestamp": "2026-07-01T14:00:00+00:00",
          "parties": [
            {"id": "agent-a", "role": "recommender", "name": "Agent A"},
            {"id": "user-1", "role": "buyer", "name": "User"}
          ]
        },
        "evidence": [
          {
            "evidence_id": "e-tv003-1",
            "claim_ref": "c-tv003",
            "type": "conversation",
            "source": "agent-a",
            "timestamp": "2026-07-01T14:00:10+00:00",
            "data": {
              "action": "recommend_product",
              "product_id": "prod-002",
              "message": "推荐产品 B"
            },
            "hash": "PLACEHOLDER_COMPUTE_SHA256"
          },
          {
            "evidence_id": "e-tv003-2",
            "claim_ref": "c-tv003",
            "type": "crm",
            "source": "crm-system",
            "timestamp": "2026-07-01T13:30:00+00:00",
            "data": {
              "action": "page_view",
              "product_id": "prod-002",
              "user_id": "user-1",
              "note": "用户此前已浏览该产品页面"
            },
            "hash": "PLACEHOLDER_COMPUTE_SHA256"
          }
        ],
        "rule": {
          "rule_id": "rule-partial-attribution-v1",
          "issuer": "did:fly:test-platform",
          "version": "1.0.0",
          "hash": "PLACEHOLDER_COMPUTE_SHA256",
          "definition": {
            "name": "部分归因规则",
            "method": "weighted",
            "description": "推荐贡献60%，用户自发40%",
            "parameters": {
              "total_value": "500",
              "currency": "USD",
              "splits": {"agent-a": "60"},
              "confidence_override": 0.7
            }
          },
          "created_at": "2026-07-01T14:00:00+00:00"
