    {
      "id": "tv-005",
      "description": "争议场景：Settlement 为 disputed 状态",
      "compliance_level": "ctrs-enterprise",
      "compliance_level_notes": "此向量涉及 disputed 状态，需要 Enterprise Extension 的争议工作流支持。Core/Governance 验证器可验证数据结构，但争议流程处理需要 Enterprise",
      "input": {
        "claim": {
          "claim_id": "c-tv005",
          "type": "disputed_conversion",
          "subject": "存在争议的转化归因",
          "description": "Agent A 和 Agent B 都声称促成了转化。交易金额 $200。",
          "timestamp": "2026-07-01T18:00:00+00:00",
          "parties": [
            {"id": "agent-a", "role": "recommender", "name": "Agent A"},
            {"id": "agent-b", "role": "recommender", "name": "Agent B"},
            {"id": "user-1", "role": "buyer", "name": "User"}
          ]
        },
        "evidence": [
          {
            "evidence_id": "e-tv005-1",
            "claim_ref": "c-tv005",
            "type": "conversation",
            "source": "agent-a",
            "timestamp": "2026-07-01T18:00:10+00:00",
            "data": {"action": "recommend", "product_id": "prod-003"},
            "hash": "PLACEHOLDER_COMPUTE_SHA256"
          },
          {
            "evidence_id": "e-tv005-2",
            "claim_ref": "c-tv005",
            "type": "conversation",
            "source": "agent-b",
            "timestamp": "2026-07-01T18:00:15+00:00",
            "data": {"action": "recommend", "product_id": "prod-003"},
            "hash": "PLACEHOLDER_COMPUTE_SHA256"
          }
        ],
        "rule": {
          "rule_id": "rule-disputed-v1",
          "issuer": "did:fly:test-platform",
          "version": "1.0.0",
          "hash": "PLACEHOLDER_COMPUTE_SHA256",
          "definition": {
            "name": "争议归因规则",
            "method": "proportional",
            "description": "暂时50/50分，等待争议解决",
            "parameters": {
              "total_value": "200",
              "currency": "USD",
              "splits": {"agent-a": "50", "agent-b": "50"}
            }
          },
          "created_at": "2026-07-01T18:00:00+00:00"
        }
      },
      "expected": {
        "report": {
          "schema_version": "CTRS-v1.2",
          "type": "CommercialTrustReport",
          "claim.claim_id": "c-tv005",
          "evidence_count": 2,
          "attribution.rule_hash": "等于 rule.hash",
          "attribution.claim_ref": "等于 claim.claim_id",
          "settlement.attribution_ref": "等于 attribution.attribution_id",
          "status": "disputed"
        },
        "verify_result": {
          "status": "valid",
          "compliance_level": "ctrs-enterprise",
          "checks": {
            "schema_completeness": true,
            "claim_integrity": true,
            "evidence_hash_integrity": true,
            "evidence_claim_ref": true,
            "attribution_consistency": true,
            "settlement_correctness": true,
            "rule_integrity": true,
            "attribution_rule_binding": true,
            "rule_registration": true,
            "issuer_trust": true
          },
          "failed_checks": [],
          "total_passed": 10,
          "total_failed": 0,
          "note": "数据结构本身验证通过，但业务状态为 disputed 需人工介入"
