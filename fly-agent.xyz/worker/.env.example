# Fly Worker 环境变量模板
# 复制此文件为 .env 并填入真实值

# IP Salt - 用于HMAC user_id伪匿名
IP_SALT=fly-salt-replace-me

# API Keys - 逗号分隔的静态API Key列表（用于Bearer鉴权）
API_KEYS=fly_replace_me_with_strong_random_key

# D1 Database ID
D1_DATABASE_ID=replace-with-your-d1-database-id

# KV Namespace ID  
KV_NAMESPACE_ID=replace-with-your-kv-namespace-id
