<script type="application/ld+json">{"@context":"https://schema.org","@graph":[{"@type":"Organization","name":"FlyAgent","url":"https://fly-agent.xyz","description":"AI获客验证基础设施，验证每一次AI获客是否赚钱","slogan":"验证每一次AI获客是否赚钱"},{"@type":"SoftwareApplication","name":"FlyAgent","applicationCategory":"BusinessApplication","operatingSystem":"Web","offers":[{"@type":"Offer","name":"Starter","price":"199","priceCurrency":"CNY","description":"AI Attribution·基础费¥199/月+有效归因成交额3%"},{"@type":"Offer","name":"Growth","price":"299","priceCurrency":"CNY","description":"Verification Layer·基础费¥299/月+有效归因成交额2%月封顶¥500"},{"@type":"Offer","name":"Enterprise","price":"2999","priceCurrency":"CNY","description":"Business Twin+Governance·¥2999/月（10店起）"}],"description":"AI获客验证基础设施——Capture→Attribution→Verification→Optimization→Business Twin"},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Fly是什么","acceptedAnswer":{"@type":"Answer","text":"Fly是AI获客验证平台。不是AI生成工具，不是自动化工具，而是验证AI带来的流量到底有没有产生真实商业结果。类似Stripe验证支付，Fly验证AI获客。"}},{"@type":"Question","name":"什么是action_id","acceptedAnswer":{"@type":"Answer","text":"action_id是Fly的归因协议标识。每条AI内容生成唯一ID，从点击→咨询→核销全链路可追溯。"}},{"@type":"Question","name":"Fly怎么收费","acceptedAnswer":{"@type":"Answer","text":"Starter ¥199/月+有效归因成交额3%，Growth ¥299/月+2%（月封顶¥500），Enterprise ¥2999/月（10店起）。30天确定归因<3个自动退款。"}}]}]}</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{
--bg:#FFFFFF;--bg2:#F8FAFC;--bg3:#F1F5F9;--bg4:#E2E8F0;
--blue:#3B82F6;--cyan:#0891B2;--green:#059669;
--dark:#0F172A;--text:#1E293B;--text2:#64748B;--text3:#94A3B8;--text4:#CBD5E1;
--mono:'JetBrains Mono',monospace;--sans:'Inter','Noto Sans SC',sans-serif;
--border:#E2E8F0;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--sans);background:var(--bg);color:var(--text);line-height:1.65;overflow-x:hidden;font-size:15px}
a{color:var(--blue);text-decoration:none;transition:opacity .2s}
a:hover{opacity:.8}

/* NAV */
header{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
header .container{display:flex;justify-content:space-between;align-items:center;height:56px}
.logo{font-family:var(--mono);font-size:18px;font-weight:700;display:flex;align-items:center;gap:6px}
.logo b{color:var(--dark)}.logo em{font-style:normal;color:var(--blue)}
.logo-tag{font-size:9px;color:var(--text3);letter-spacing:1.5px;margin-left:8px;padding:2px 7px;border:1px solid var(--text4);border-radius:3px;font-weight:400;background:var(--bg2)}
nav{display:flex;align-items:center;gap:20px}
nav a{font-size:13px;color:var(--text2);transition:color .15s;letter-spacing:.3px;font-weight:500}
nav a:hover{color:var(--dark)}
.nav-cta{padding:8px 18px;background:var(--dark);color:#fff;border:none;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;transition:opacity .2s;font-family:var(--sans)}
.nav-cta:hover{opacity:.85}

.container{max-width:1080px;margin:0 auto;padding:0 24px;position:relative;z-index:1}
.sec-label{font-family:var(--mono);font-size:11px;color:var(--blue);text-transform:uppercase;letter-spacing:3px;margin-bottom:6px}
.sec-title{font-size:28px;font-weight:700;line-height:1.3;margin-bottom:6px;letter-spacing:-.5px;color:var(--dark)}
.sec-desc{font-size:14px;color:var(--text2);margin-bottom:28px;max-width:560px}

/* ===== HERO ===== */
.hero{padding:120px 0 80px;min-height:100vh;display:flex;align-items:center;border-bottom:1px solid var(--border)}
.hero .container{display:flex;gap:60px;align-items:center}
.hero-text{flex:1}
.hero h1{font-size:44px;font-weight:700;line-height:1.2;letter-spacing:-1px;color:var(--dark)}
.hero h1 em{font-style:normal;color:var(--blue)}
.hero-sub{font-size:16px;color:var(--text2);margin-top:12px;max-width:480px;line-height:1.7}
.hero-trust{display:flex;gap:20px;margin-top:18px;flex-wrap:wrap}
.hero-trust span{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text2);font-weight:500}
.hero-trust .ico{width:20px;height:20px;background:var(--bg3);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:12px}
.hero-btns{display:flex;gap:10px;margin-top:24px;flex-wrap:wrap}
.btn-p{padding:12px 28px;background:var(--dark);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:opacity .2s;font-family:var(--sans)}
.btn-p:hover{opacity:.85}
.btn-s{padding:12px 28px;background:transparent;color:var(--text2);border:1px solid var(--text4);border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;font-family:var(--sans)}
.btn-s:hover{border-color:var(--text3);color:var(--dark)}

/* Dashboard card - white card on hero */
.hero-cards{width:380px;flex-shrink:0;display:flex;flex-direction:column;gap:12px}
.hero-card{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:18px 20px;transition:border-color .2s}
.hero-card:hover{border-color:var(--blue)}
.hero-card-icon{font-size:20px;margin-bottom:8px}
.hero-card-title{font-size:14px;font-weight:600;color:var(--dark);margin-bottom:4px}
.hero-card-desc{font-size:12px;color:var(--text2);line-height:1.6}
.hero-card-tag{display:inline-block;font-size:10px;color:var(--blue);padding:2px 8px;border:1px solid rgba(59,130,246,.2);border-radius:10px;margin-top:8px;font-weight:500}

/* ===== PROBLEM ===== */
#problem{padding:80px 0;background:var(--bg2);border-bottom:1px solid var(--border)}
.problem-flow{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:24px;font-size:14px;color:var(--text2)}
.problem-flow .node{padding:6px 16px;background:var(--bg);border:1px solid var(--border);border-radius:6px;font-size:13px;font-weight:500}
.problem-flow .break{color:#DC2626;font-weight:600;font-size:12px;font-family:var(--mono)}
.compare-table{width:100%;border-collapse:collapse;margin-bottom:28px;font-size:13px;border:1px solid var(--border);border-radius:8px;overflow:hidden}
.compare-table th{text-align:left;padding:12px 16px;background:var(--bg3);color:var(--text2);font-size:11px;font-weight:600;letter-spacing:1px;border-bottom:1px solid var(--border)}
.compare-table td{padding:12px 16px;border-bottom:1px solid var(--border);color:var(--text2)}
.compare-table tr:last-child td{border-bottom:none}
.compare-table td:first-child{color:var(--dark);font-weight:500}
.compare-table .fly-col{color:var(--blue);font-weight:500}
.problem-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.problem-card{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:24px}
.problem-card .num{font-family:var(--mono);font-size:11px;color:var(--blue);margin-bottom:10px}
.problem-card h3{font-size:14px;font-weight:600;margin-bottom:6px;color:var(--dark)}
.problem-card p{font-size:13px;color:var(--text2);line-height:1.6}

/* ===== ARCHITECTURE ===== */
#architecture{padding:80px 0;border-bottom:1px solid var(--border)}
.arch-layers{max-width:640px}
.arch-layer{display:flex;align-items:center;gap:14px;padding:16px 20px;background:var(--bg2);border:1px solid var(--border);border-radius:8px;margin-bottom:4px}
.arch-ico{font-size:18px;min-width:24px;text-align:center}
.arch-lname{font-size:14px;font-weight:600;color:var(--dark)}
.arch-value{font-size:12px;color:var(--text2);margin-top:2px}
.arch-arrow{text-align:center;padding:2px 0;color:var(--text4);font-size:10px}

/* ===== PROTOCOL ===== */
#protocol{padding:80px 0;background:var(--bg2);border-bottom:1px solid var(--border)}
.proto-steps{display:grid;gap:12px}
.proto-step{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:24px;display:flex;gap:16px;align-items:flex-start;border-left:3px solid var(--blue)}
.proto-num{font-family:var(--mono);font-size:28px;font-weight:700;color:var(--blue);line-height:1;min-width:36px}
.proto-content h3{font-size:15px;font-weight:600;margin-bottom:4px;color:var(--dark)}
.proto-content p{font-size:13px;color:var(--text2);line-height:1.6}
.proto-content strong{color:var(--dark);font-weight:600}

/* ===== DASHBOARD ===== */
#dashboard{padding:80px 0;border-bottom:1px solid var(--border)}
.metrics-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:20px}
.metric-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:20px}
.metric-label{font-size:11px;color:var(--text3);margin-bottom:6px;font-family:var(--mono);text-transform:uppercase;letter-spacing:1px}
.metric-value{font-size:28px;font-weight:700;font-family:var(--mono);color:var(--dark)}
.metric-value.green{color:var(--green)}
.metric-value.blue{color:var(--blue)}
.metric-sub{font-size:11px;color:var(--text3);margin-top:4px}
.path-row{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:12px;color:var(--text2);flex-wrap:wrap;padding:14px 18px;background:var(--bg2);border:1px solid var(--border);border-radius:8px}
.path-row .arrow{color:var(--text4)}

/* ===== TWIN ===== */
#twin{padding:80px 0;background:var(--bg2);border-bottom:1px solid var(--border)}
.twin-card{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:28px;max-width:560px}
.twin-card h3{font-size:15px;font-weight:600;margin-bottom:12px;color:var(--dark)}
.twin-sim{display:grid;gap:6px;margin-top:12px}
.twin-row{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg2);border-radius:6px;font-size:13px}
.twin-row .param{color:var(--text2)}
.twin-row .result{font-family:var(--mono);font-weight:600}
.twin-row .result.up{color:var(--green)}
.twin-row .result.same{color:var(--text3)}

/* ===== ENTERPRISE ===== */
#enterprise{padding:80px 0;border-bottom:1px solid var(--border)}
.ent-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.ent-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:24px}
.ent-card h3{font-size:14px;font-weight:600;margin-bottom:8px;display:flex;align-items:center;gap:8px;color:var(--dark)}
.ent-card h3 .icon{font-size:10px;color:var(--blue)}
.ent-card p{font-size:13px;color:var(--text2);line-height:1.6}
.ent-card ul{list-style:none;margin-top:8px}
.ent-card li{font-size:12px;color:var(--text2);padding:4px 0}
.ent-card li::before{content:'';display:inline-block;width:4px;height:4px;background:var(--blue);border-radius:50%;margin-right:8px;vertical-align:middle}

/* ===== ONBOARDING ===== */
#onboarding{padding:80px 0;background:var(--bg2);border-bottom:1px solid var(--border)}
.onboard-steps{display:flex;gap:12px;margin-top:24px;flex-wrap:nowrap;overflow-x:auto}
.onboard-step{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:16px 14px;text-align:center;min-width:140px;flex:1}
.onboard-num{font-family:var(--mono);font-size:24px;font-weight:700;color:var(--dark);opacity:.15;margin-bottom:6px}
.onboard-step h3{font-size:13px;font-weight:600;margin-bottom:4px;color:var(--dark)}
.onboard-step p{font-size:11px;color:var(--text2);line-height:1.5}
.onboard-cta{margin-top:32px;text-align:center}

/* ===== PRICING ===== */
#pricing{padding:80px 0;border-bottom:1px solid var(--border)}
.price-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.price-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:28px 24px;position:relative}
.price-card.feat{border-color:var(--blue);box-shadow:0 0 0 1px var(--blue),0 8px 24px rgba(59,130,246,.08)}
.price-badge{position:absolute;top:-10px;left:50%;transform:translateX(-50%);padding:3px 12px;background:var(--blue);color:#fff;border-radius:10px;font-size:10px;font-weight:600}
.price-tier{font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:2px;margin-bottom:6px}
.price-name{font-size:16px;font-weight:700;margin-bottom:4px;color:var(--dark)}
.price-amount{font-family:var(--mono);font-size:32px;font-weight:700;margin-bottom:2px;color:var(--dark)}
.price-amount span{font-size:14px;color:var(--text2);font-weight:400}
.price-extra{font-size:11px;color:var(--text3);margin-bottom:16px}
.price-features{list-style:none;margin-bottom:20px}
.price-features li{font-size:12px;color:var(--text2);padding:6px 0;border-bottom:1px solid var(--border)}
.price-features li:last-child{border:none}
.price-btn{display:block;width:100%;padding:10px;border:1px solid var(--text4);background:var(--bg);color:var(--dark);border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;font-family:var(--sans)}
.price-btn:hover{border-color:var(--blue);color:var(--blue)}
.price-card.feat .price-btn{background:var(--dark);border-color:var(--dark);color:#fff;font-weight:600}
.price-card.feat .price-btn:hover{opacity:.85}
.price-guarantee{margin-top:24px;padding:20px 24px;background:var(--bg2);border:1px solid var(--border);border-radius:8px;text-align:center}
.price-guarantee .title{font-size:14px;font-weight:600;margin-bottom:8px;color:var(--dark)}
.price-guarantee p{font-size:12px;color:var(--text2);line-height:1.7}
.price-note{font-size:11px;color:var(--text3);font-family:var(--mono);text-align:center;margin-top:20px}

/* ===== FAQ ===== */
#faq{padding:80px 0;background:var(--bg2)}
.faq-cats{display:flex;gap:8px;margin-bottom:24px;flex-wrap:wrap}
.faq-cat{padding:6px 14px;background:var(--bg);border:1px solid var(--border);border-radius:20px;font-size:12px;color:var(--text2);cursor:pointer;transition:all .15s;font-weight:500}
.faq-cat.active,.faq-cat:hover{border-color:var(--blue);color:var(--blue);background:var(--bg3)}
.faq-list{max-width:720px;display:grid;gap:0}
.faq-item{border-bottom:1px solid var(--border)}
.faq-item[data-cat]{display:none}
.faq-item.show{display:block}
.faq-q{font-size:14px;font-weight:500;padding:16px 0;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:color .15s;color:var(--dark)}
.faq-q:hover{color:var(--blue)}
.faq-q .pm{font-family:var(--mono);font-size:14px;color:var(--text3)}
.faq-a{font-size:13px;color:var(--text2);padding:0 0 16px;display:none;line-height:1.7}
.faq-item.open .faq-a{display:block}
.faq-item.open .faq-q .pm{color:var(--blue)}

/* ===== FOOTER ===== */
footer{padding:40px 0;border-top:1px solid var(--border)}
.footer-grid{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
.footer-brand{font-size:14px;font-weight:600;color:var(--dark)}
.footer-brand em{font-style:normal;color:var(--blue)}
.footer-links{display:flex;gap:16px;flex-wrap:wrap}
.footer-links a{font-size:12px;color:var(--text3)}
.footer-links a:hover{color:var(--dark)}
.footer-copy{width:100%;text-align:center;margin-top:20px;font-size:10px;color:var(--text4);font-family:var(--mono)}

/* Legal */
.legal-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.3);backdrop-filter:blur(4px);justify-content:center;align-items:center}
.legal-overlay.show{display:flex}
.legal-card{background:var(--bg);border:1px solid var(--border);border-radius:12px;padding:32px;max-width:480px;width:90%;max-height:80vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.1)}
.legal-card h2{font-size:20px;margin-bottom:16px;color:var(--dark)}
.legal-card h3{font-size:13px;margin:16px 0 6px;color:var(--dark)}
.legal-card p{font-size:12px;color:var(--text2);line-height:1.7}
.legal-close{margin-top:20px;padding:8px 20px;background:var(--bg2);border:1px solid var(--border);color:var(--dark);border-radius:6px;cursor:pointer;font-size:12px}

/* Mobile */
@media(max-width:768px){
.hero h1{font-size:28px}
.hero .container{flex-direction:column;gap:32px}
.hero-cards{width:100%}
.hero{padding-top:90px;min-height:auto}
.problem-grid,.price-grid,.metrics-grid,.ent-grid{grid-template-columns:1fr!important}
nav{display:none}
.compare-table{font-size:11px}
.compare-table th,.compare-table td{padding:8px 6px}
.hero-btns{flex-direction:column;width:100%}
.btn-p,.btn-s{width:100%;text-align:center}
}

/* Sandbox styles */
.sandbox-banner{font-size:12px;color:var(--text2);background:var(--bg3);padding:10px 16px;border-radius:6px;margin-bottom:16px;border:1px solid var(--border)}
.sandbox-tag{font-size:11px;color:var(--text3);background:var(--bg3);padding:2px 6px;border-radius:4px;margin-left:8px;font-family:var(--mono)}

/* Attribution flow visualization */
.attribution-flow{display:flex;align-items:center;justify-content:center;gap:12px;padding:24px 16px;background:var(--bg2);border-radius:12px;flex-wrap:wrap}
.attribution-flow .step{text-align:center;padding:16px;border-radius:8px;background:var(--bg);border:1px solid var(--border);min-width:110px}
.attribution-flow .step.active{border-color:var(--blue);background:#EFF6FF}
.attribution-flow .step .label{font-weight:600;font-size:14px;color:var(--dark)}
.attribution-flow .step .detail{font-size:12px;color:var(--text2);margin-top:4px}
.attribution-flow .arrow{color:var(--text4);font-size:18px;font-weight:700}

/* SVG icon */
.ico-svg{display:inline;vertical-align:middle}
</style>
</head>
<body>

<header>
<div class="container">
<div class="logo"><b>Fly</b><em>.</em><span class="logo-tag">AI获客验证平台</span></div>
<nav>
<a href="#problem">痛点</a>
<a href="#architecture">架构</a>
<a href="#protocol">归因协议</a>
<a href="#pricing">定价</a>
<a href="#enterprise">企业版</a>
<a href="#twin">数字孪生</a>
<a href="#faq">FAQ</a>
</nav>
<button class="nav-cta" onclick="copyWechat()">免费开启沙盒验证</button>
</div>
</header>

<!-- HERO -->
<section class="hero" id="hero">
<div class="container">
<div class="hero-text">
<h1>AI获客，<em>算清</em>每一笔账</h1>
<p style="font-size:13px;color:var(--text3);margin-top:8px;font-family:var(--mono);letter-spacing:.5px">归因追踪 · 合约托管 · 按效果付费 · 数据可追溯
<span style="font-size:10px;color:var(--text3);margin-left:12px;opacity:.7">[ action_id · 已验证 · ready ]</span></p>
