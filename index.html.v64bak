<script>
function copyWechat(){
  navigator.clipboard.writeText("One1913U");
  const b=event.target.closest('button');
  if(b){const orig=b.textContent;b.textContent="已复制微信号 ✓";setTimeout(()=>{b.textContent=orig},2000)}
}

document.querySelectorAll('.faq-q').forEach(q=>{
  q.addEventListener('click',()=>{
    const item=q.parentElement;
    const wasOpen=item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(i=>i.classList.remove('open'));
    if(!wasOpen)item.classList.add('open');
  });
});
function filterFaq(cat){
  document.querySelectorAll('.faq-cat').forEach(c=>c.classList.remove('active'));
  event.target.classList.add('active');
  document.querySelectorAll('.faq-item[data-cat]').forEach(item=>{
    if(cat==='all'||item.dataset.cat===cat){item.classList.add('show')}else{item.classList.remove('show');item.classList.remove('open')}
  });
}
document.querySelectorAll('a[href^="#"],nav a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{e.preventDefault();const t=document.querySelector(a.getAttribute('href'));if(t)t.scrollIntoView({behavior:'smooth'})});
});
function showPrivacy(){document.getElementById('legalContent').innerHTML='<h2>隐私政策</h2><p style="color:var(--text3);margin-bottom:14px">最后更新：2026年5月</p><h3>数据收集</h3><p>我们仅收集action_id、脱敏ID、订单号、金额、访问时间。不收集身份证号、银行卡号等敏感信息。</p><h3>数据使用</h3><p>您的数据仅用于：1）归因验证和优化建议；2）生成经营报告；3）优化服务质量。不会出售给第三方。</p><h3>数据安全</h3><p>采用HMAC-SHA256+随机盐脱敏，不可逆还原。核心经营行为记录经可信验证后永久保存，不可篡改。日常数据存储在加密服务器中，仅您本人可访问。</p><h3>您的权利</h3><p>您有权随时查看、导出您的数据。其他数据可在要求后7个工作日内删除。</p><button class="legal-close" onclick="document.getElementById(\'legalOverlay\').classList.remove(\'show\')">关闭</button>';document.getElementById('legalOverlay').classList.add('show')}
function showTerms(){document.getElementById('legalContent').innerHTML='<h2>服务条款</h2><p style="color:var(--text3);margin-bottom:14px">最后更新：2026年5月</p><h3>服务内容</h3><p>FlyAgent提供AI获客归因验证、GEO优化、经营可信验证等服务。AI生成建议后需经用户确认方可执行。</p><h3>付费与退款</h3><p>Starter ¥199/月+成交额3%，Growth ¥299/月+成交额2%（月封顶¥500），Enterprise ¥2999/月（10店起）。退款保障：L1自动判定+L2平台48h复核+L3争议调解+L4司法兜底。</p><h3>免责声明</h3><p>AI生成的诊断建议和内容仅供参考，经营决策由用户自行承担。</p><button class="legal-close" onclick="document.getElementById(\'legalOverlay\').classList.remove(\'show\')">关闭</button>';document.getElementById('legalOverlay').classList.add('show')}
function showContact(){document.getElementById('legalContent').innerHTML='<h2>联系我们</h2><p>微信：One1913U</p><p>邮箱：fly-agent@coze.email</p><p>公司：杭州九运智领科技</p><p>工作时间：周一至周五 9:00-18:00</p><button class="legal-close" onclick="document.getElementById(\'legalOverlay\').classList.remove(\'show\')">关闭</button>';document.getElementById('legalOverlay').classList.add('show')}
